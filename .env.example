# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── WhatsApp / Meta Cloud API ─────────────────────────────────────────────────
# From Meta Developer Console → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=1234567890          # Your WhatsApp Business phone number ID
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx    # Temporary or permanent access token
WA_VERIFY_TOKEN=my-secret-verify-token # Any string you choose — used once during webhook setup

# ── Google Calendar ───────────────────────────────────────────────────────────
# Path to the credentials.json you downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
# Path where the OAuth token will be cached after first auth
GOOGLE_TOKEN_FILE=token.json
# Your Google Calendar timezone
CALENDAR_TIMEZONE=America/Chicago

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000
